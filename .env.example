SECRET_KEY=replace-with-secure-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///database/deepguard.db
MODEL_TIMEOUT=30
MAX_PAYLOAD_MB=50

APP_NAME=DeepGuard API Gateway
APP_ENV=dev
APP_USERNAME=admin
APP_PASSWORD=admin123
APP_VIEWER_USERNAME=viewer
APP_VIEWER_PASSWORD=viewer123

ENSEMBLE_METHOD=stacking
FAKE_THRESHOLD=0.5
MODEL_REGISTRY_PATH=configs/models.yaml
MAX_IMAGE_PIXELS=50000000
RATE_LIMIT_PER_MINUTE=60
FAIL_OPEN_ON_MODEL_ERROR=true

KAGGLE_DATASET_SLUG=shivamardeshna/real-and-fake-images-dataset-for-image-forensics
TRAINING_DATA_DIR=data/raw/image_forensics
KAGGLE_UNZIP=true
